{
  "manifest_version": 3,
  "name": "TAA - Claude Usage Tracker",
  "version": "0.11.0",
  "description": "See in plain English how much of your Claude usage is left and when it resets. Runs 100% on your machine.",
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    { "matches": ["https://claude.ai/*"], "js": ["hook.js"], "run_at": "document_start", "world": "MAIN" },
    { "matches": ["https://claude.ai/*"], "js": ["content.js"], "run_at": "document_idle" }
  ],
  "action": { "default_popup": "popup.html", "default_title": "TAA - Claude Usage Tracker" }
}
